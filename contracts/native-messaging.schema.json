{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": {"major": 1, "minor": 2},
  "consumer_support": {"major": 1, "min_minor": 0, "max_minor": 2},
  "type": "object",
  "required": ["schemaVersion", "type"],
  "properties": {
    "schemaVersion": {
      "type": "object",
      "required": ["major", "minor"],
      "properties": {
        "major": {"const": 1},
        "minor": {"type": "integer", "minimum": 0, "maximum": 2}
      }
    },
    "type": {
      "enum": [
        "ARM_SESSION",
        "HEARTBEAT",
        "DISPATCH_TRIGGER",
        "RECONCILE_TRIGGER",
        "USER_TURN_ACKED",
        "ASSISTANT_STARTED",
        "TURN_IDLE",
        "TURN_TIMEOUT",
        "RECONCILE_MISMATCH",
        "SESSION_LOST",
        "SEND_UNCERTAIN",
        "DISARM_SESSION",
        "DIAGNOSTIC_EVENT",
        "DIAGNOSTIC_ACK"
      ]
    },
    "requestId": {"type": "string", "minLength": 1},
    "responseToRequestId": {"type": "string", "minLength": 1},
    "sessionId": {"type": "string", "minLength": 1},
    "jobId": {"type": "string", "format": "uuid"},
    "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "envelope": {"type": "string"},
    "envelopeSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reviewMode": {"enum": ["pr-comment", "relay-only"]},
    "deadline": {"type": "string", "format": "date-time"},
    "allowUnsentSend": {"type": "boolean"},
    "capabilities": {"type": "array", "items": {"type": "string", "enum": ["relay-only-v1", "diagnostics-v1"]}},
    "errorCode": {"type": "string", "minLength": 1},
    "assistantOutput": {"type": "string", "minLength": 1, "maxLength": 131072},
    "level": {"enum": ["error", "info", "debug", "trace"]},
    "component": {"type": "string", "minLength": 1, "maxLength": 64},
    "event": {"type": "string", "minLength": 1, "maxLength": 96},
    "eventId": {"type": "string", "minLength": 1, "maxLength": 160},
    "sourceTimestamp": {"type": "string", "format": "date-time"},
    "sequence": {"type": "integer", "minimum": 0},
    "bindingGeneration": {"type": "string", "minLength": 1, "maxLength": 160},
    "documentId": {"type": "string", "minLength": 1, "maxLength": 160},
    "tabId": {"type": "integer", "minimum": 0},
    "persisted": {"type": "boolean"},
    "details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "job_id": {"type": "string", "maxLength": 160},
        "message_type": {"type": "string", "maxLength": 160},
        "phase": {"type": "string", "maxLength": 160},
        "error_code": {"type": "string", "maxLength": 160},
        "state": {"type": "string", "maxLength": 160},
        "length": {"type": "integer", "minimum": 0},
        "count": {"type": "integer", "minimum": 0},
        "candidate_count": {"type": "integer", "minimum": 0},
        "exact_match_count": {"type": "integer", "minimum": 0},
        "baseline_count": {"type": "integer", "minimum": 0},
        "generating": {"type": "boolean"},
        "response_idle": {"type": "boolean"},
        "quiet": {"type": "boolean"},
        "stable": {"type": "boolean"},
        "completion_observed": {"type": "boolean"}
      }
    }
  }
}
