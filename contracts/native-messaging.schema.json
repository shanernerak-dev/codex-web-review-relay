{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": {"major": 1, "minor": 3},
  "consumer_support": {"major": 1, "min_minor": 0, "max_minor": 3},
  "type": "object",
  "required": ["schemaVersion", "type"],
  "properties": {
    "schemaVersion": {
      "type": "object",
      "required": ["major", "minor"],
      "properties": {
        "major": {"const": 1},
        "minor": {"type": "integer", "minimum": 0, "maximum": 3}
      }
    },
    "type": {
      "enum": [
        "ARM_SESSION",
        "HEARTBEAT",
        "DISPATCH_TRIGGER",
        "RECONCILE_TRIGGER",
        "USER_TURN_ACKED",
        "ASSISTANT_STARTED",
        "TURN_IDLE",
        "TURN_TIMEOUT",
        "RECONCILE_MISMATCH",
        "SESSION_LOST",
        "SEND_UNCERTAIN",
        "DISARM_SESSION",
        "DIAGNOSTIC_EVENT",
        "DIAGNOSTIC_ACK",
        "DISPATCH_TRIGGER_ACCEPTED",
        "RECONCILE_TRIGGER_ACCEPTED"
      ]
    },
    "requestId": {"type": "string", "minLength": 1},
    "responseToRequestId": {"type": "string", "minLength": 1},
    "sessionId": {"type": "string", "minLength": 1},
    "jobId": {"type": "string", "format": "uuid"},
    "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "envelope": {"type": "string"},
    "envelopeSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reviewMode": {"enum": ["pr-comment", "relay-only"]},
    "deadline": {"type": "string", "format": "date-time"},
    "allowUnsentSend": {"type": "boolean"},
    "capabilities": {"type": "array", "items": {"type": "string", "enum": ["relay-only-v1", "diagnostics-v1"]}},
    "errorCode": {"type": "string", "minLength": 1},
    "assistantOutput": {"type": "string", "minLength": 1, "maxLength": 131072},
    "level": {"enum": ["error", "info", "debug", "trace"]},
    "component": {"type": "string", "minLength": 1, "maxLength": 64},
    "event": {"type": "string", "minLength": 1, "maxLength": 96},
    "eventId": {"type": "string", "minLength": 1, "maxLength": 160},
    "sourceTimestamp": {"type": "string", "format": "date-time"},
    "sequence": {"type": "integer", "minimum": 0},
    "bindingGeneration": {"type": "string", "minLength": 1, "maxLength": 160},
    "documentId": {"type": "string", "minLength": 1, "maxLength": 160},
    "tabId": {"type": "integer", "minimum": 0},
    "persisted": {"type": "boolean"},
    "disposition": {"enum": ["appended", "duplicate", "filtered"]},
    "ownershipGeneration": {"type": "integer", "minimum": 0},
    "details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "job_id": {"type": "string", "maxLength": 160},
        "message_type": {"type": "string", "maxLength": 160},
        "phase": {"type": "string", "maxLength": 160},
        "error_code": {"type": "string", "maxLength": 160},
        "state": {"type": "string", "maxLength": 160},
        "length": {"type": "integer", "minimum": 0},
        "count": {"type": "integer", "minimum": 0},
        "candidate_count": {"type": "integer", "minimum": 0},
        "exact_match_count": {"type": "integer", "minimum": 0},
        "baseline_count": {"type": "integer", "minimum": 0},
        "turn_key_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "fragment_key_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "classification": {"enum": ["baseline", "new"]},
        "role": {"enum": ["user", "assistant", "unknown"]},
        "turn_index": {"type": "integer", "minimum": 0},
        "fragment_index": {"type": "integer", "minimum": 0},
        "fragment_count": {"type": "integer", "minimum": 0},
        "content_observed": {"type": "boolean"},
        "fragment_extracted": {"type": "boolean"},
        "byte_length": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "generating": {"type": "boolean"},
        "response_idle": {"type": "boolean"},
        "quiet": {"type": "boolean"},
        "stable": {"type": "boolean"},
        "completion_observed": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {"const": "DIAGNOSTIC_ACK"},
          "schemaVersion": {"properties": {"minor": {"minimum": 3}}, "required": ["minor"]}
        },
        "required": ["type", "schemaVersion"]
      },
      "then": {
        "required": ["responseToRequestId", "persisted", "disposition"],
        "oneOf": [
          {"properties": {"persisted": {"const": true}, "disposition": {"enum": ["appended", "duplicate"]}}},
          {"properties": {"persisted": {"const": false}, "disposition": {"const": "filtered"}}}
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {"enum": ["DISPATCH_TRIGGER", "RECONCILE_TRIGGER", "USER_TURN_ACKED", "ASSISTANT_STARTED", "TURN_IDLE", "TURN_TIMEOUT", "RECONCILE_MISMATCH", "SESSION_LOST", "SEND_UNCERTAIN", "DISPATCH_TRIGGER_ACCEPTED", "RECONCILE_TRIGGER_ACCEPTED"]},
          "schemaVersion": {"properties": {"minor": {"minimum": 3}}, "required": ["minor"]}
        },
        "required": ["type", "schemaVersion"]
      },
      "then": {"required": ["ownershipGeneration"]}
    },
    {
      "if": {"properties": {"type": {"enum": ["DISPATCH_TRIGGER", "RECONCILE_TRIGGER"]}}, "required": ["type"]},
      "then": {"required": ["requestId", "sessionId", "jobId", "fingerprint", "envelope", "envelopeSha256", "deadline"]}
    },
    {
      "if": {
        "properties": {
          "type": {"enum": ["DISPATCH_TRIGGER", "RECONCILE_TRIGGER"]},
          "schemaVersion": {"properties": {"minor": {"minimum": 1}}, "required": ["minor"]}
        },
        "required": ["type", "schemaVersion"]
      },
      "then": {"required": ["reviewMode"]}
    },
    {
      "if": {
        "properties": {
          "type": {"const": "RECONCILE_TRIGGER"},
          "schemaVersion": {"properties": {"minor": {"minimum": 1}}, "required": ["minor"]}
        },
        "required": ["type", "schemaVersion"]
      },
      "then": {"required": ["allowUnsentSend"]}
    },
    {
      "if": {"properties": {"type": {"enum": ["DISPATCH_TRIGGER_ACCEPTED", "RECONCILE_TRIGGER_ACCEPTED"]}}, "required": ["type"]},
      "then": {"required": ["responseToRequestId", "sessionId", "jobId"]}
    },
    {
      "if": {"properties": {"type": {"enum": ["USER_TURN_ACKED", "ASSISTANT_STARTED", "TURN_IDLE", "TURN_TIMEOUT", "RECONCILE_MISMATCH", "SESSION_LOST", "SEND_UNCERTAIN"]}}, "required": ["type"]},
      "then": {"required": ["requestId", "sessionId", "jobId"]}
    },
    {
      "if": {"properties": {"type": {"const": "TURN_IDLE"}}, "required": ["type"]},
      "then": {"required": ["assistantOutput"]}
    }
  ]
}
