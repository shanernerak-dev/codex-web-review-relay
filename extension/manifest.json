{
  "manifest_version": 3,
  "name": "Codex Web Review Relay",
  "version": "0.3.0",
  "key": "",
  "description": "Manually armed ChatGPT transport adapter for repository-owned review handoffs.",
  "permissions": ["activeTab", "nativeMessaging", "storage", "tabs"],
  "host_permissions": ["https://chatgpt.com/*"],
  "background": {"service_worker": "background.js"},
  "action": {"default_popup": "popup.html"},
  "content_scripts": [{"matches": ["https://chatgpt.com/*"], "js": ["dom-adapter.js", "content.js"], "run_at": "document_idle"}]
}
