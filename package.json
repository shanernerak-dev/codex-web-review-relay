{
  "name": "codex-web-review-relay",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/cli.ts native-host",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "test:compat": "node --experimental-strip-types scripts/verify-compatibility.ts",
    "smoke:native": "node --experimental-strip-types scripts/smoke-native-host.ts",
    "check:release-version": "python scripts/check-release-version.py",
    "package:release": "python scripts/package-release.py",
    "check:release-assets": "python scripts/check-release-assets.py"
  }
}
